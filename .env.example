# Copy this file to repo-root `.env` or `backend/.env`.

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120
PERSISTENCE_DB_PATH=backend/data/nudiscribe.db

ENABLE_TTS=true
ENABLE_TTS_FALLBACK_TONE=true
TTS_SAMPLE_RATE=22050

# AI4Bharat Indic-TTS primary path for Hindi/Kannada.
# If INDIC_TTS_COMMAND_TEMPLATE is left empty, the backend will run:
#   {INDIC_TTS_PYTHON_BIN} -m TTS.bin.synthesize ...
INDIC_TTS_PYTHON_BIN=python
INDIC_TTS_COMMAND_TEMPLATE=

INDIC_TTS_MODEL_HI=
INDIC_TTS_CONFIG_HI=
INDIC_TTS_VOCODER_HI=
INDIC_TTS_VOCODER_CONFIG_HI=

INDIC_TTS_MODEL_KN=
INDIC_TTS_CONFIG_KN=
INDIC_TTS_VOCODER_KN=
INDIC_TTS_VOCODER_CONFIG_KN=

# English / fallback providers
PIPER_BINARY=
PIPER_VOICE_EN=
PIPER_VOICE_HI=
PIPER_VOICE_KN=

COQUI_MODEL_EN=
COQUI_MODEL_HI=
COQUI_MODEL_KN=
COQUI_SPEAKER=

# Optional multilingual ASR continual-training pipeline.
# Enable runtime archival if you want uploaded/live audio copied into a weakly
# supervised corpus for later retraining.
ASR_ARCHIVE_AUDIO_FOR_TRAINING=false
ASR_CORPUS_DIR=backend/data/asr_corpus
ASR_ARCHIVE_DIR=backend/data/asr_corpus/local_archive
ASR_CHECKPOINT_DIR=backend/data/asr_checkpoints
ASR_BASE_MODEL=openai/whisper-small
ASR_HF_TOKEN=
ASR_TARGET_HOURS_PER_BUCKET=40
ASR_TARGET_CODE_MIXED_HOURS=20
ASR_LOCAL_ARCHIVE_HOURS_PER_BUCKET=5
ASR_EVAL_RATIO=0.1
ASR_MAX_CLIP_SECONDS=30
ASR_TRAIN_EPOCHS=3
ASR_TRAIN_LEARNING_RATE=1e-5
ASR_TRAIN_BATCH_SIZE=4
ASR_EVAL_BATCH_SIZE=4
ASR_GRADIENT_ACCUMULATION_STEPS=4
ASR_LOGGING_STEPS=25
ASR_SAVE_STEPS=500
ASR_EVAL_STEPS=500
ASR_WARMUP_STEPS=250
